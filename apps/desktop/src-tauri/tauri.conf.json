{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local AI Router",
  "version": "0.1.0",
  "identifier": "com.bilalalissa.local-ai-router",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Local AI Router",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "nsis"],
    "category": "DeveloperTool",
    "shortDescription": "Local-first AI model router",
    "longDescription": "Local-first desktop app for routing and managing compatible local AI models across macOS and Windows."
  }
}
